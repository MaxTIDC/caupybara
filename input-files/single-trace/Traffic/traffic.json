{
  "spec_name": "TrafficE2",
  "env": [
    "carA",
    "carB",
    "emergency"
  ],
  "sys": [
    "greenA",
    "greenB"
  ],
  "assumptions": {
    "ini !carA & !carB & !emergency": [],
    "alwEv carA": [],
    "alwEv carB": [],
    "alwEv !emergency": [],
    "alw carA & !greenA -> next(carA)": [],
    "alw carB & !greenB -> next(carB)": [],
    "alw carA & greenA -> next(!carA)": [],
    "alw carB & greenB -> next(!carB)": []
  },
  "guarantees": {
    "ini !greenA &!greenB": [],
    "alw greenA -> !greenB": [],
    "alw greenB -> !greenA": [],
    "alwEv greenA": [],
    "alwEv greenB": [],
    "alw emergency -> !greenA & !greenB": []
  }
}